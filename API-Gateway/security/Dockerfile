# Лёгкий базовый образ: полноценный Python, но без лишних системных пакетов
# полного образа python:3.12 (меньше размер, меньше поверхность атаки).
FROM python:3.12-slim

WORKDIR /app

# Сначала копируем только requirements.txt и ставим зависимости — это
# отдельный слой Docker-кеша. Если менять только app.py, пересборка
# не будет заново качать и ставить одни и те же пакеты.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Код сервиса копируем последним слоем, так как меняется чаще всего.
COPY app.py .

ENV PORT=8000
EXPOSE 8000

# gunicorn вместо встроенного дев-сервера Flask — устойчивее под нагрузкой
# и предназначен для использования в контейнерах/проде.
CMD ["gunicorn", "-b", "0.0.0.0:8000", "app:app"]
